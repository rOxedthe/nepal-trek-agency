e\":\"dark\"}],[\"$\",\"div\",null,{\"className\":\"container-trek relative z-10 grid items-center gap-12 lg:grid-cols-2\",\"children\":[[\"$\",\"$L5\",null,{\"className\":\"relative h-[420px] overflow-hidden rounded-3xl shadow-trek\",\"children\":[\"$\",\"$L2\",null,{\"src\":\"https://images.unsplash.com/photo-1528360983277-13d401cdc186?w=1000&q=80&auto=format&fit=crop\",\"alt\":\"Our guides on a Himalayan trail\",\"fill\":true,\"sizes\":\"(max-width:1024px) 100vw, 50vw\",\"className\":\"object-cover\"}]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"eyebrow text-amber-600\",\"children\":\"Our Story\"}],[\"$\",\"h2\",null,{\"className\":\"mt-3 font-playfair text-4xl font-bold text-green-900\",\"children\":\"A team of locals with a shared love of the mountains\"}],[\"$\",\"p\",null,{\"className\":\"mt-5 font-lato leading-relaxed text-stone-800\",\"children\":\"Nepal Trek Agency began in 2010 in the narrow lanes of Boudha, Kathmandu, founded by a handful of guides who had spent their lives on these trails. We were tired of seeing visitors handed cookie-cutter itineraries by faceless operators — so we built something different.\"}],[\"$\",\"p\",null,{\"className\":\"mt-4 font-lato leading-relaxed text-stone-800\",\"children\":\"Every trek we run is led by a guide born and raised in the Himalayas. We keep groups small, we look after our porters, and we treat the mountains with the respect they deserve. Fifteen years and a thousand expeditions later, that hasn't changed.\"}],[\"$\",\"$L4\",null,{\"href\":\"/contact\",\"className\":\"btn btn-amber group mt-8\",\"children\":[\"Plan With Us \",[\"$\",\"svg\",null,{\"viewBox\":\"0 0 24 24\",\"fill\":\"none\",\"stroke\":\"currentColor\",\"strokeWidth\":1.8,\"strokeLinecap\":\"round\",\"strokeLinejoin\":\"round\",\"width\":18,\"height\":18,\"className\":\"transition-transform group-hover:translate-x-1\",\"children\":[\"$\",\"path\",null,{\"d\":\"M5 12h14M13 6l6 6-6 6\"}]}]]}]]}]]}]]}],[\"$\",\"section\",null,{\"className\":\"relative overflow-hidden bg-green-900 section-pad text-snow\",\"children\":[[\"$\",\"$L3\",null,{\"variant\":\"mountains\",\"tone\":\"light\"}],[\"$\",\"div\",null,{\"className\":\"container-trek relative z-10\",\"children\":[[\"$\",\"$L6\",null,{\"eyebrow\":\"Our Journey\",\"title\":\"Milestones on the Trail\",\"tone\":\"light\"}],[\"$\",\"div\",null,{\"className\":\"mt-14 grid gap-6 md:grid-cols-5\",\"children\":[[\"$\",\"$L5\",\"2010\",{\"i\":0,\"className\":\"relative rounded-2xl border border-snow/10 bg-green-800/50 p-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-playfair text-3xl font-bold text-amber-400\",\"children\":\"2010\"}],\"$L7\"]}],\"$L8\",\"$L9\",\"$La\",\"$Lb\"]}]]}]]}],\"$Lc\",\"$Ld\"],[\"$Le\"],\"$Lf\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"Yvxwku2KmYQcmPK9XVSvX\"}\n7:[\"$\",\"p\",null,{\"className\":\"mt-3 font-lato text-sm leading-relaxed text-snow/80\",\"children\":\"Founded in Boudha, Kathmandu by a small team of Sherpa and Gurung guides.\"}]\n8:[\"$\",\"$L5\",\"2013\",{\"i\":1,\"className\":\"relative rounded-2xl border border-snow/10 bg-green-800/50 p-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-playfair text-3xl font-bold text-amber-400\",\"children\":\"2013\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 font-lato text-sm leading-relaxed text-snow/80\",\"children\":\"Became a registered TAAN member and licensed by the Nepal Tourism Board.\"}]]}]\n9:[\"$\",\"$L5\",\"2016\",{\"i\":2,\"className\":\"relative rounded-2xl border border-snow/10 bg-green-800/50 p-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-playfair text-3xl font-bold text-amber-400\",\"children\":\"2016\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 font-lato text-sm leading-relaxed text-snow/80\",\"children\":\"Expanded into restricted regions — Upper Mustang, Manaslu and Tsum Valley.\"}]]}]\na:[\"$\",\"$L5\",\"2020\",{\"i\":3,\"className\":\"relative rounded-2xl border border-snow/10 bg-green-800/50 p-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-playfair text-3xl font-bold text-amber-400\",\"children\":\"2020\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 font-lato text-sm leading-relaxed text-snow/80\",\"children\":\"Launched our Leave No Trace programme and porter welfare charter.\"}]]}]\nb:[\"$\",\"$L5\",\"2024\",{\"i\":4,\"className\":\"relative rounded-2xl border border-snow/10 bg-green-800/50 p-6\",\"children\":[[\"$\",\"p\",null,{\"className\":\"font-playfair text-3xl font-bold text-amber-400\",\"children\":\"2024\"}],[\"$\",\"p\",null,{\"className\":\"mt-3 font-lato text-sm leading-relaxed text-snow/80\",\"children\":\"Crossed 1,000 successful expeditions with a 98% satisfaction rate.\"}]]}]\nc:[\"$\",\"section\",null,{\"className\":\"relative overflow-hidden bg-warm section-pad\",\"children\":[[\"$\",\"$L3\",null,{\"variant\":\"pines\",\"tone\":\"dark\"}],[\"$\",\"div\",null,{\"className\":\"container-trek relative z-10\",\"children\":[[\"$\",\"$L6\",null,{\"eyebrow\":\"The People\",\"title\":\"Meet Your Guides\",\"subtitle\":\"Hover or tap a card to read each guide's story.\"}],[\"$\",\"div\",null,{\"className\":\"mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4\",\"children\":[[\"$\",\"$L10\",\"Bhupendra Tamang\",{\"guide\":{\"name\":\"Bhupendra Tamang\",\"role\":\"Lead Guide · Everest Expert\",\"speciality\":\"Everest Base Camp, Gokyo\",\"years\":15,\"languages\":\"Nepali, English, Hindi\",\"bio\":\"Bhupendra has summited Kala Patthar over 40 times and leads our highest-altitude expeditions with calm authority.\",\"image\":\"https://images.unsplash.com/photo-1539701938214-0d9736e1c16b?w=800&q=80&auto=format&fit=crop\"},\"index\":0}],[\"$\",\"$L10\",\"Dip Sherpa\",{\"guide\":{\"name\":\"Dip Sherpa\",\"role\":\"Annapurna Specialist\",\"speciality\":\"Annapurna Circuit & Base Camp\",\"years\":12,\"languages\":\"Nepali, English, French\",\"bio\":\"Raised in the Annapurna foothills, Dip knows every teahouse and hidden viewpoint alon