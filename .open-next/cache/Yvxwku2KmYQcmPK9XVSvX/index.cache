ox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" width=\"18\" height=\"18\" class=\"text-snow/40 transition-transform duration-200 group-active:translate-x-1\"><path d=\"M5 12h14M13 6l6 6-6 6\"></path></svg></div></button><a class=\"col-span-2 flex items-center justify-between rounded-2xl border border-snow/15 bg-green-900/40 px-5 py-4 transition-all active:scale-95\" href=\"/treks\"><span class=\"font-dm text-lg text-snow\">Browse all treks</span><span class=\"inline-flex items-center gap-1.5 rounded-full border border-snow/20 px-3 py-1.5 font-montserrat text-xs text-snow/70\">12<!-- --> routes <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\" width=\"13\" height=\"13\"><path d=\"M5 12h14M13 6l6 6-6 6\"></path></svg></span></a></div><div class=\"mt-10 hidden h-[460px] w-full md:block\"><!--$!--><template data-dgst=\"BAILOUT_TO_CLIENT_SIDE_RENDERING\"></template><div class=\"flex h-full w-full items-center justify-center\"><div class=\"h-40 w-40 animate-pulse rounded-full bg-green-700/40\"></div></div><!--/$--></div></div></section><section class=\"relative overflow-hidden bg-warm section-pad\"><div aria-hidden=\"true\" class=\"pointer-events-none absolute inset-0 z-0 overflow-hidden \"><svg class=\"absolute inset-0 h-full w-full\" preserveAspectRatio=\"xMidYMid slice\" viewBox=\"0 0 600 600\"><g fill=\"none\" stroke=\"#4D0014\" stroke-width=\"1.2\" style=\"opacity:0.07\"><ellipse cx=\"300\" cy=\"300\" rx=\"60\" ry=\"42\" class=\"animate-pulse-ring\" style=\"transform-origin:300px 300px;animation-delay:0s\"></ellipse><ellipse cx=\"300\" cy=\"300\" rx=\"108\" ry=\"78\" class=\"animate-pulse-ring\" style=\"transform-origin:300px 300px;animation-delay:0.6s\"></ellipse><ellipse cx=\"300\" cy=\"300\" rx=\"156\" ry=\"114\" class=\"animate-pulse-ring\" style=\"transform-origin:300px 300px;animation-delay:1.2s\"